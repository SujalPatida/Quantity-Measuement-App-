public class QuantityMeasurementApp {

    public static void main(String[] args) {

        QuantityLength l1 = new QuantityLength(1, LengthUnit.FEET);
        QuantityLength l2 = new QuantityLength(12, LengthUnit.INCHES);

        // UC7: Addition with target unit
        QuantityLength result = QuantityLength.add(l1, l2, LengthUnit.YARDS);
        System.out.println("Addition Result: " + result);

        // Conversion
        QuantityLength converted = l1.convertTo(LengthUnit.CENTIMETERS);
        System.out.println("Converted: " + converted);

        // Comparison
        QuantityLength l3 = new QuantityLength(2, LengthUnit.FEET);
        System.out.println("Are equal: " + l3.equals(l1.add(l1, new QuantityLength(0, LengthUnit.FEET), LengthUnit.FEET)));

        // Subtraction
        QuantityLength diff = QuantityLength.subtract(l3, l1, LengthUnit.FEET);
        System.out.println("Subtraction Result: " + diff);
    }
}

/* =========================
   Standalone LengthUnit
   ========================= */
enum LengthUnit {

    FEET(1.0),
    INCHES(1.0 / 12.0),
    YARDS(3.0),
    CENTIMETERS(0.0328084);

    private final double toBaseFactor; // base = FEET

    LengthUnit(double toBaseFactor) {
        this.toBaseFactor = toBaseFactor;
    }

    // Convert THIS unit → base unit (feet)
    public double convertToBaseUnit(double value) {
        return value * toBaseFactor;
    }

    // Convert base unit (feet) → THIS unit
    public double convertFromBaseUnit(double baseValue) {
        return baseValue / toBaseFactor;
    }
}

/* =========================
   QuantityLength Class
   ========================= */
class QuantityLength {

    private final double value;
    private final LengthUnit unit;

    public QuantityLength(double value, LengthUnit unit) {
        if (unit == null) {
            throw new IllegalArgumentException("Unit cannot be null");
        }
        if (!Double.isFinite(value)) {
            throw new IllegalArgumentException("Value must be finite");
        }
        this.value = value;
        this.unit = unit;
    }

    public double getValue() {
        return value;
    }

    public LengthUnit getUnit() {
        return unit;
    }

    // 🔁 Convert to another unit
    public QuantityLength convertTo(LengthUnit targetUnit) {
        if (targetUnit == null) {
            throw new IllegalArgumentException("Target unit cannot be null");
        }

        double baseValue = unit.convertToBaseUnit(value);
        double converted = targetUnit.convertFromBaseUnit(baseValue);

        return new QuantityLength(converted, targetUnit);
    }

    // ➕ UC7 Add with target unit
    public static QuantityLength add(
            QuantityLength l1,
            QuantityLength l2,
            LengthUnit targetUnit) {

        if (l1 == null || l2 == null) {
            throw new IllegalArgumentException("Operands cannot be null");
        }
        if (targetUnit == null) {
            throw new IllegalArgumentException("Target unit cannot be null");
        }

        double base1 = l1.unit.convertToBaseUnit(l1.value);
        double base2 = l2.unit.convertToBaseUnit(l2.value);

        double sumBase = base1 + base2;

        double result = targetUnit.convertFromBaseUnit(sumBase);

        return new QuantityLength(result, targetUnit);
    }

    // ➖ Subtraction
    public static QuantityLength subtract(
            QuantityLength l1,
            QuantityLength l2,
            LengthUnit targetUnit) {

        if (l1 == null || l2 == null) {
            throw new IllegalArgumentException("Operands cannot be null");
        }
        if (targetUnit == null) {
            throw new IllegalArgumentException("Target unit cannot be null");
        }

        double base1 = l1.unit.convertToBaseUnit(l1.value);
        double base2 = l2.unit.convertToBaseUnit(l2.value);

        double diffBase = base1 - base2;

        double result = targetUnit.convertFromBaseUnit(diffBase);

        return new QuantityLength(result, targetUnit);
    }

    // ⚖️ Equality check
    public boolean equals(QuantityLength other) {
        if (other == null) return false;

        double thisBase = unit.convertToBaseUnit(value);
        double otherBase = other.unit.convertToBaseUnit(other.value);

        return Math.abs(thisBase - otherBase) < 0.0001;
    }

    @Override
    public String toString() {
        return value + " " + unit;
    }
}
