// Enum for Length Units
enum LengthUnit {
    FEET(1.0),                 // base unit
    INCHES(1.0 / 12.0),       // 1 inch = 1/12 feet
    YARDS(3.0),               // 1 yard = 3 feet
    CENTIMETERS(0.0328084);   // 1 cm = 0.0328084 feet

    private final double conversionFactorToFeet;

    LengthUnit(double conversionFactorToFeet) {
        this.conversionFactorToFeet = conversionFactorToFeet;
    }

    public double toBase(double value) {
        return value * conversionFactorToFeet;
    }

    public double fromBase(double baseValue) {
        return baseValue / conversionFactorToFeet;
    }
}


// QuantityLength Class
class QuantityLength {

    private final double value;
    private final LengthUnit unit;

    public QuantityLength(double value, LengthUnit unit) {
        if (!Double.isFinite(value)) {
            throw new IllegalArgumentException("Value must be finite");
        }
        if (unit == null) {
            throw new IllegalArgumentException("Unit cannot be null");
        }
        this.value = value;
        this.unit = unit;
    }

    // Instance Conversion Method
    public double convertTo(LengthUnit targetUnit) {
        if (targetUnit == null) {
            throw new IllegalArgumentException("Target unit cannot be null");
        }

        double baseValue = unit.toBase(this.value); // convert to feet
        return targetUnit.fromBase(baseValue);      // convert to target
    }

    // Static Conversion Method
    public static double convert(double value, LengthUnit sourceUnit, LengthUnit targetUnit) {
        if (!Double.isFinite(value)) {
            throw new IllegalArgumentException("Value must be finite");
        }
        if (sourceUnit == null || targetUnit == null) {
            throw new IllegalArgumentException("Units cannot be null");
        }

        double baseValue = sourceUnit.toBase(value); // convert to feet
        return targetUnit.fromBase(baseValue);       // convert to target
    }

    // Optional: Equality check (from previous UC)
    public boolean equals(QuantityLength other, double epsilon) {
        double thisInFeet = this.unit.toBase(this.value);
        double otherInFeet = other.unit.toBase(other.value);
        return Math.abs(thisInFeet - otherInFeet) < epsilon;
    }
}


// Test Class
public class Main {
    public static void main(String[] args) {

        // Static method usage
        double inches = QuantityLength.convert(1, LengthUnit.FEET, LengthUnit.INCHES);
        System.out.println("1 foot = " + inches + " inches");

        double cm = QuantityLength.convert(2, LengthUnit.YARDS, LengthUnit.CENTIMETERS);
        System.out.println("2 yards = " + cm + " cm");

        // Instance method usage
        QuantityLength length = new QuantityLength(100, LengthUnit.CENTIMETERS);
        double feet = length.convertTo(LengthUnit.FEET);
        System.out.println("100 cm = " + feet + " feet");
    }
}
